#!/bin/bash

# ── Bar appearance ──────────────────────────────────────────
sketchybar --bar \
  height=32 \
  blur_radius=30 \
  position=top \
  sticky=on \
  show_in_fullscreen=on \
  padding_left=10 \
  padding_right=10 \
  color=0xdd1e1e2e   # ARGB hex (dark background)

# ── Default item styling ────────────────────────────────────
sketchybar --default \
  padding_left=5 \
  padding_right=5 \
  icon.font="SF Pro:Bold:14.0" \
  label.font="SF Pro:Regular:13.0" \
  icon.color=0xffcdd6f4 \
  label.color=0xffcdd6f4 \
  icon.padding_left=4 \
  icon.padding_right=4 \
  label.padding_left=4 \
  label.padding_right=4

# ── Left: Space indicators ──────────────────────────────────
SPACE_ICONS=("1" "2" "3" "4" "5")

for i in "${!SPACE_ICONS[@]}"; do
  sid=$(( i + 1 ))
  sketchybar --add space space.$sid left \
             --set space.$sid \
               space=$sid \
               icon="${SPACE_ICONS[i]}" \
               icon.padding_left=8 \
               icon.padding_right=8 \
               background.color=0x44cdd6f4 \
               background.corner_radius=5 \
               background.height=24 \
               background.drawing=off \
               label.drawing=off \
               script="$HOME/.config/sketchybar/plugins/space.sh"
done

# ── Center: Clock ───────────────────────────────────────────
sketchybar --add item clock center \
           --set clock \
             update_freq=10 \
             icon=󱑍 \
             script="$HOME/.config/sketchybar/plugins/clock.sh"

# ── Right: Battery ──────────────────────────────────────────
sketchybar --add item battery right \
           --set battery \
             update_freq=60 \
             script="$HOME/.config/sketchybar/plugins/battery.sh"

# ── Finalise ────────────────────────────────────────────────
sketchybar --update
