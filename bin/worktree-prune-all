#!/usr/bin/env bash

# written entirely with claude!! use at own discretion
# this script will delete worktrees which no longer have a remote, but did at one point
# use --dry-run first to check what will be deleted

dry_run=false

for arg in "$@"; do
  case "$arg" in
    --dry-run|-n) dry_run=true ;;
  esac
done

$dry_run && echo "[DRY RUN] No changes will be made"$'\n'

if $dry_run; then
  echo "[DRY RUN] Would run: git fetch --prune"
else
  git fetch --prune
fi

main_wt="$(git rev-parse --show-toplevel)"

gone_branches=$(git for-each-ref \
  --format='%(refname:short) %(upstream:track)' refs/heads \
  | awk '$2 == "[gone]" { print $1 }')

# Use process substitution instead of a pipe to avoid a subshell
while read -r path branch; do
  [ "$path" = "$main_wt" ] && continue
  [ -z "$branch" ] && continue

  short="${branch#refs/heads/}"

  if echo "$gone_branches" | grep -qx "$short"; then
    if $dry_run; then
      echo "[DRY RUN] Would remove worktree: $path"
      echo "[DRY RUN] Would delete branch:   $short"
    else
      echo "Removing worktree: $path (branch: $short)"
      git worktree remove --force "$path"
      git branch -D "$short"
    fi
  fi
done < <(git worktree list --porcelain | awk '
  /^worktree / { wt = $2 }
  /^branch /   { branch = $2 }
  /^$/          { print wt, branch }
')

if $dry_run; then
  echo $'\n'"[DRY RUN] Would run: git worktree prune"
else
  git worktree prune
fi
